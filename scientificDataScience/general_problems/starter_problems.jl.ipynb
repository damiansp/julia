   "source": [
    "function strangmatrix(n::Int)\n",
    "    m = zeros(n, n)\n",
    "    m[1, 1:2] = [-2 1]\n",
    "    m[n, (n - 1):n] = [1 -2]\n",
    "    for i in 2:(n - 1)\n",
    "        m[i, (i - 1):(i + 1)] = [1 -2 1]\n",
    "    end\n",
    "    m\n",
    "end"
   ]
  },
