   "source": [
    "function distance(x1, y1, x2, y2)\n",
    "    dx = x2 - x1\n",
    "    dy = y2 - y1\n",
    "    dsq = dx^2 + dy^2\n",
    "    @show dsq\n",
    "    sqrt(dsq)\n",
    "end"
   ]
  },
